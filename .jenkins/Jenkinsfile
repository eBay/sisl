pipeline {
    agent { label 'sds-builder-v8' }

    environment {
        ARTIFACTORY_PASS = credentials('ARTIFACTORY_PASS')
    }

    stages {
        stage('Get Version') {
            steps {
                script {
                    PROJECT = sh(script: "grep -m 1 'name =' conanfile.py | awk '{print \$3}' | tr -d '\n' | tr -d '\"'", returnStdout: true)
                    CONAN_FLAGS = "-s:h compiler.cppstd=23 --build missing --build '${PROJECT}*'"
                    VER = sh(script: "grep -m 1 ' version =' conanfile.py | awk '{print \$3}' | tr -d '\n' | tr -d '\"'", returnStdout: true)
                    slackSend color: '#0063D1', channel: '#sds-ci', message: "*${PROJECT}:${VER} (${BRANCH_NAME})* is building : ${BUILD_URL}"
                }
            }
        }

        stage('Tag with Channel') {
            when { not { branch "stable/v*" } }
            steps {
                script {
                    CONAN_CHANNEL = sh(script: "echo ${BRANCH_NAME} | sed -E 's,(\\w+-?\\d*)/.*,\\1,' | sed -E 's,-,_,' | tr -d '\n'", returnStdout: true)
                    CONAN_FLAGS = "${CONAN_FLAGS} --user oss --channel ${CONAN_CHANNEL}"
                }
            }
        }

        stage("Build") {
            steps {
                sh "conan create -s:h build_type=Debug ${CONAN_FLAGS} ."
                sh "conan create -s:h build_type=RelWithDebInfo -o sisl/*:malloc_impl=tcmalloc ${CONAN_FLAGS} ."
            }
        }

        stage("Deploy to Artifactory") {
            when {
                expression { !(env.BRANCH_NAME =~ /PR-/) }
            }
            steps {
                sh "conan remote login -p ${ARTIFACTORY_PASS} ebay-local _service_sds"
                sh "conan upload '*:*' -r ebay-local --confirm"
            }
        }
    }

    post {
        failure {
            slackSend color: '#E43237', channel: '#sds-ci', message: "*${PROJECT}:${VER} (${BRANCH_NAME})* has had a failure : ${BUILD_URL}"
        }
        success {
            slackSend color: '#85B717', channel: '#sds-ci', message: "*${PROJECT}:${VER} (${BRANCH_NAME})* has completed."
        }
    }
}
